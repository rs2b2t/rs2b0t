{
    "name": "rs2b0t-desktop",
    "version": "0.1.0",
    "private": true,
    "description": "rs2b0t desktop client (Electron shell, no background throttling)",
    "main": "main.cjs",
    "scripts": {
        "start": "electron .",
        "start:solo": "electron . --server=http://localhost:8888/bot.html",
        "package": "electron-builder --dir"
    },
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.0.0"
    },
    "build": {
        "appId": "rs.lostcity.rs2b0t",
        "productName": "rs2b0t",
        "files": ["main.cjs"],
        "directories": {
            "output": "dist"
        },
        "mac": {
            "identity": null
        }
    }
}
